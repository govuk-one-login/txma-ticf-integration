{
  "parser": "@typescript-eslint/parser",
  "extends": ["plugin:vitest/recommended", "eslint:recommended", "prettier"],
  "env": {
    "vitest/globals": true,
    "node": true
  },
  "rules": {
    "no-console": "error",
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_*" }]
  },
  "overrides": [
    {
      "files": ["scripts/**/*", "tests/**"],
      "rules": { "no-console": ["off"] }
    }
  ],
  "plugins": ["vitest"]
}
