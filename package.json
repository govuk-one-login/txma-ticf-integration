{
  "name": "txma-ticf-integration",
  "description": "System to automate the retrieval of audit data via Zendesk integration",
  "repository": {
    "type": "git",
    "url": "https://github.com/govuk-one-login/txma-ticf-integration"
  },
  "author": "GDS",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run bundleApiSpecs && tsc --noEmit && tsx ./esbuild.config.ts",
    "bundleApiSpecs": "mkdir -p dist && cp -f open-api-specification.yaml dist/open-api-specification.yaml",
    "createTestTicket": "FIXED_RECIPIENT_EMAIL=$0 FIXED_DATA_REQUEST_DATE=$1 FIXED_SUBJECT_LINE=$2 OVERRIDE_EVENT_IDS=$3 DATA_PATHS=$4 tsx scripts/createAndApproveZendeskTicket.ts",
    "lint": "prettier . --check || exit 1 ; eslint . --max-warnings=0",
    "lint:fix": "prettier . --write ; eslint . --fix",
    "manualAuditDataRequest:initiateCopyAndDecrypt": "tsx scripts/manualAuditDataRequestInitiateCopyAndDecrypt.ts",
    "postinstall": "husky",
    "setupDevStackSecrets": "tsx scripts/setupDevStackSecrets.ts",
    "test": "vitest run -c vitest.config.ts",
    "test:cov": "vitest run -c vitest.config.ts --coverage",
    "test:e2e": "vitest run -c tests/e2e-tests/vitest.e2e.config.ts",
    "test:e2e:dev": "vitest run -c tests/e2e-tests/vitest.e2e.config.ts",
    "test:integration": "vitest run -c tests/integration-tests/vitest.integration.config.ts",
    "test:integration:dev": "vitest run -c tests/integration-tests/vitest.integration.config.ts",
    "validRecipientsManager": "tsx scripts/validRecipientsManager.ts",
    "cli": "tsx scripts/cli.ts",
    "migration:step1": "glacier_to_glacierir_migration/run-migration.sh step1-initiate-restore.sh",
    "migration:step2": "glacier_to_glacierir_migration/run-migration.sh step2-create-backup.sh",
    "migration:step3": "glacier_to_glacierir_migration/run-migration.sh step3-migrate.sh",
    "migration:help": "glacier_to_glacierir_migration/run-migration.sh --help"
  },
  "dependencies": {
    "@aws-crypto/decrypt-node": "4.2.2",
    "@aws-crypto/kms-keyring-node": "4.2.2",
    "@aws-crypto/material-management": "4.2.2",
    "@aws-lambda-powertools/logger": "^2.32.0",
    "@aws-sdk/client-athena": "^3.1015.0",
    "@aws-sdk/client-dynamodb": "^3.1015.0",
    "@aws-sdk/client-s3": "^3.1015.0",
    "@aws-sdk/client-s3-control": "^3.1015.0",
    "@aws-sdk/client-secrets-manager": "^3.1015.0",
    "@aws-sdk/client-sns": "^3.1015.0",
    "@aws-sdk/client-sqs": "^3.1015.0",
    "@aws-sdk/util-endpoints": "3.996.5",
    "notifications-node-client": "8.3.0",
    "typescript-eslint": "^8.57.2"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudformation": "^3.1000.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1000.0",
    "@aws-sdk/client-iam": "^3.1000.0",
    "@aws-sdk/client-lambda": "^3.1000.0",
    "@aws-sdk/client-ssm": "^3.1000.0",
    "@aws-sdk/client-sts": "^3.1000.0",
    "@commander-js/extra-typings": "14.0.0",
    "@types/aws-lambda": "8.10.158",
    "@types/node": "24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/eslint-plugin": "1.6.9",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-client-mock-vitest": "^7.0.1",
    "axios": "1.13.5",
    "commander": "14.0.2",
    "csv-string": "4.1.1",
    "esbuild": "0.27.0",
    "eslint": "9.39.1",
    "@eslint/js": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "globals": "^17.4.0",
    "husky": "9.1.7",
    "lint-staged": "16.2.6",
    "node-html-parser": "7.0.1",
    "prettier": "3.8.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.18",
    "vitest-when": "^0.10.0",
    "yaml-cfn": "0.3.2"
  },
  "resolutions": {
    "micromatch": "4.0.8"
  },
  "lint-staged": {
    "*": "prettier --write",
    "*.{js,ts}": "eslint --fix"
  },
  "engines": {
    "node": "^24.0.0"
  },
  "overrides": {
    "fast-xml-parser": "5.5.6"
  }
}
